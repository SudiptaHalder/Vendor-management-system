// ========================================
// VENDORFLOW - MINIMAL SCHEMA (FIXED)
// ========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================================
// ADMIN USERS (for uploading)
// ========================================

model users {
  id           String    @id @default(cuid())
  email        String    @unique
  password     String?
  name         String?
  role         String    @default("admin")
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  uploadedFiles vendor_upload_data[]

  @@index([email])
  @@map("users")
}

// ========================================
// VENDORS (created from uploads)
// ========================================

model vendors {
  id              String    @id @default(cuid())
  supplierCode    String    @unique
  supplierName    String
  email           String?
  plantCode       String?
  status          String    @default("active")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  // Relations
  credentials     vendor_credentials?
  uploadRecords   vendor_upload_data[]
  purchaseOrders  purchase_orders[]
  invitations     vendor_invitations[]
}

// ========================================
// VENDOR CREDENTIALS (for login)
// ========================================

model vendor_credentials {
  id              String    @id @default(cuid())
  vendorId        String    @unique
  vendor          vendors   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  
  // Login credentials
  username        String    @unique
  password        String
  tempPassword    String?
  
  // Status
  isActive        Boolean   @default(true)
  isTempPassword  Boolean   @default(true)
  lastLoginAt     DateTime?
  passwordChangedAt DateTime?
  
  // Invitation
  invitationSent  Boolean   @default(false)
  invitationToken String?   @unique
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([username])
  @@index([vendorId])
  @@map("vendor_credentials")
}

// ========================================
// PURCHASE ORDERS (from Excel)
// ========================================

model purchase_orders {
  id              String    @id @default(cuid())
  
  // PO Info
  poNumber        String    @unique
  vendorId        String
  vendor          vendors   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  
  // Dates
  poCreateDate    DateTime?
  poAmendDate     DateTime?
  
  // Status
  status          String    @default("draft")
  
  // Tracking
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  lineItems       purchase_order_line_items[]
  uploadRecords   vendor_upload_data[]

  @@index([poNumber])
  @@index([vendorId])
  @@map("purchase_orders")
}

// ========================================
// PURCHASE ORDER LINE ITEMS (from Excel)
// ========================================

model purchase_order_line_items {
  id              String    @id @default(cuid())
  
  // PO Reference
  purchaseOrderId String
  purchaseOrder   purchase_orders @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  
  // Item Details
  lineNumber      Int?
  materialCode    String?
  materialDesc    String?
  orderUnit       String?
  rate            Decimal?  @db.Decimal(19,4)
  invoiceQuantity Decimal?  @db.Decimal(19,4)
  
  // Tracking
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  uploadRecords   vendor_upload_data[]

  @@index([purchaseOrderId])
  @@map("purchase_order_line_items")
}

// ========================================
// RAW UPLOAD DATA (audit trail)
// ========================================

model vendor_upload_data {
  id              String    @id @default(cuid())
  
  // Who uploaded
  uploadedById    String
  uploadedBy      users     @relation(fields: [uploadedById], references: [id])
  
  // File info
  fileName        String
  rowNumber       Int
  uploadedAt      DateTime  @default(now())
  
  // Status
  status          String    @default("processed")
  errorMessage    String?
  
  // Raw Excel data
  email           String?
  supplierCode    String
  supplierName    String
  plantCode       String?
  poNumber        String
  poCreateDate    DateTime?
  poAmendDate     DateTime?
  materialCode    String?
  materialDesc    String?
  lineItem        Int?
  orderUnit       String?
  rate            Decimal?  @db.Decimal(19,4)
  invoiceQuantity Decimal?  @db.Decimal(19,4)
  
  // Relations to created records
  vendorId        String?
  vendor          vendors?         @relation(fields: [vendorId], references: [id])
  poId            String?
  purchaseOrder   purchase_orders? @relation(fields: [poId], references: [id])
  lineItemId      String?
  poLineItem      purchase_order_line_items? @relation(fields: [lineItemId], references: [id])

  @@index([supplierCode])
  @@index([poNumber])
  @@index([vendorId])
  @@index([uploadedAt])
  @@map("vendor_upload_data")
}

// ========================================
// VENDOR INVITATIONS (email tracking)
// ========================================

model vendor_invitations {
  id              String    @id @default(cuid())
  vendorId        String
  vendor          vendors   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  
  email           String
  username        String
  tempPassword    String
  invitationToken String    @unique
  
  status          String    @default("pending")
  sentAt          DateTime?
  acceptedAt      DateTime?
  expiresAt       DateTime
  
  createdAt       DateTime  @default(now())

  @@index([vendorId])
  @@index([invitationToken])
  @@index([status])
  @@map("vendor_invitations")
}
