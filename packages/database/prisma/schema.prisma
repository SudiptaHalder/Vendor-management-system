// ========================================
// VENDORFLOW - COMPLETE SCHEMA
// ========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================================
// ADMIN USERS (for uploading)
// ========================================

model users {
  id           String    @id @default(cuid())
  email        String    @unique
  password     String?
  name         String?
  role         String    @default("admin")
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  uploadedFiles           vendor_upload_data[]
  createdPurchaseOrders   purchase_orders[] @relation("POCreatedBy")

  @@index([email])
  @@map("users")
}

// ========================================
// VENDORS (created from uploads)
// ========================================

model vendors {
  id              String    @id @default(cuid())
  supplierCode    String    @unique
  supplierName    String
  email           String?
  plantCode       String?
  status          String    @default("active")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  credentials     vendor_credentials?
  uploadRecords   vendor_upload_data[]
  purchaseOrders  purchase_orders[]
  invitations     vendor_invitations[]
  masterData      VendorMaster?

  @@map("vendors")
}

// ========================================
// VENDOR MASTER DATA (detailed vendor info)
// ========================================

model VendorMaster {
  id                    String    @id @default(cuid())
  supplierCode          String    @unique
  supplierName          String
  companyCode           String?
  supplierAcctGroup     String?
  countryName           String?
  city                  String?
  bankName              String?
  bankAccount           String?
  taxNumber             String?
  postingBlock          Boolean?   @default(false)
  purchasingBlock       Boolean?   @default(false)
  paymentMethods        String?
  deletionFlag          Boolean?   @default(false)
  createdBy             String?
  accountHolder         String?
  accountingClerk       String?
  accountingClerkTel    String?
  address               String?
  alternativePayee      String?
  alternativePayeeCC    String?
  authorization         String?
  automaticPO           Boolean?   @default(false)
  bankControlKey        String?
  bankCountry           String?
  bankKey               String?
  bpBankAccount         String?
  bpPOBoxDvtgCity       String?
  bpType                String?
  branchCode            String?
  branchDescription     String?
  businessPartner       String?
  checkDoubleInvoice    Boolean?   @default(false)
  clerkFaxNo            String?
  countryKey            String?
  createdOn             DateTime?
  defaultBranch         String?
  email                 String?
  faxNumber             String?
  grBasedInvVerif       Boolean?   @default(false)
  iban                  String?
  incoterms             String?
  incotermsPart2        String?
  internetAdd           String?
  itemPaymentBlock      Boolean?   @default(false)
  liableForVAT          Boolean?   @default(true)
  minorityIndicator     String?
  naturalPerson         Boolean?   @default(false)
  orderCurrency         String?
  paymentBlock          Boolean?   @default(false)
  planningGroup         String?
  postalCode            String?
  previousAccountNo     String?
  purchOrganization     String?
  purchasingGroup       String?
  reconAccount          String?
  referenceDetails      String?
  region                String?
  releaseGroup          String?
  searchTerm1           String?
  searchTerm2           String?
  sortKey               String?
  street                String?
  street2               String?
  street3               String?
  street4               String?
  street5               String?
  supplierFullName      String?
  swiftBic              String?
  taxNumber1            String?
  taxNumber2            String?
  taxNumber3            String?
  taxNumber4            String?
  taxNumber5            String?
  taxNumberAtAuth       String?
  taxNumberCategory     String?
  taxNumberType         String?
  taxType               String?
  taxTypeName           String?
  telephone1            String?
  telephone2            String?
  termsOfPaytsKeyCoCode String?
  termsOfPaytsKeyPO     String?
  tradingPartnerNo      String?
  wTaxCRKey             String?
  
  // Relations
  vendor                vendors   @relation(fields: [supplierCode], references: [supplierCode])
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("vendor_master")
}

// ========================================
// VENDOR CREDENTIALS (for login)
// ========================================

model vendor_credentials {
  id              String    @id @default(cuid())
  vendorId        String    @unique
  vendor          vendors   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  
  // Login credentials
  username        String    @unique
  password        String
  tempPassword    String?
  
  // Status
  isActive        Boolean   @default(true)
  isTempPassword  Boolean   @default(true)
  lastLoginAt     DateTime?
  passwordChangedAt DateTime?
  
  // Invitation
  invitationSent  Boolean   @default(false)
  invitationToken String?   @unique
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([username])
  @@index([vendorId])
  @@map("vendor_credentials")
}

// ========================================
// PURCHASE ORDERS (enhanced)
// ========================================

model purchase_orders {
  id              String    @id @default(cuid())
  
  // PO Basic Info
  poNumber        String    @unique
  poType          String?   // Standard, Contract, etc.
  plantCode       String?   // Plant location
  vendorId        String
  vendor          vendors   @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  
  // Dates
  poCreateDate    DateTime?
  poAmendDate     DateTime?
  expectedDate    DateTime?
  deliveredDate   DateTime?
  
  // Status
  status          String    @default("draft") // draft, pending, approved, completed, cancelled
  
  // Financial
  subtotal        Decimal?  @db.Decimal(19,4)
  taxAmount       Decimal?  @db.Decimal(19,4)
  totalAmount     Decimal?  @db.Decimal(19,4)
  currency        String?   @default("INR")
  
  // Tracking
  createdById     String?
  createdBy       users?    @relation("POCreatedBy", fields: [createdById], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  lineItems       po_line_items[]
  legacyLineItems purchase_order_line_items[]
  uploadRecords   vendor_upload_data[]

  @@index([poNumber])
  @@index([vendorId])
  @@index([status])
  @@map("purchase_orders")
}

// ========================================
// PURCHASE ORDER LINE ITEMS (enhanced)
// ========================================

model po_line_items {
  id              String    @id @default(cuid())
  
  // PO Reference
  purchaseOrderId String
  purchaseOrder   purchase_orders @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  
  // Line Item Details
  lineNumber      Int       @default(1)
  materialCode    String?
  materialDesc    String?
  uom             String?   // Unit of Measure (EA, KG, etc.)
  
  // Quantities
  quantity        Decimal?  @db.Decimal(19,4)
  receivedQty     Decimal?  @db.Decimal(19,4) @default(0)
  pendingQty      Decimal?  @db.Decimal(19,4) @default(0)
  
  // Pricing
  unitPrice       Decimal?  @db.Decimal(19,4)
  discountPercent Decimal?  @db.Decimal(5,2) @default(0)
  discountAmount  Decimal?  @db.Decimal(19,4) @default(0)
  taxableValue    Decimal?  @db.Decimal(19,4)
  
  // Tax Details
  gstPercent      Decimal?  @db.Decimal(5,2)  // Total GST percentage
  sgstPercent     Decimal?  @db.Decimal(5,2)  // State GST
  cgstPercent     Decimal?  @db.Decimal(5,2)  // Central GST
  igstPercent     Decimal?  @db.Decimal(5,2)  // Integrated GST
  gstAmount       Decimal?  @db.Decimal(19,4)
  
  // Total
  totalAmount     Decimal?  @db.Decimal(19,4) // (taxableValue + gstAmount) or (quantity * unitPrice)
  
  // Delivery
  expectedDate    DateTime?
  deliveredDate   DateTime?
  
  // Status
  status          String    @default("pending") // pending, partial, completed
  
  // Tracking
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([purchaseOrderId])
  @@map("po_line_items")
}

// ========================================
// LEGACY PURCHASE ORDER LINE ITEMS (for backward compatibility)
// ========================================

model purchase_order_line_items {
  id              String    @id @default(cuid())
  
  // PO Reference
  purchaseOrderId String
  purchaseOrder   purchase_orders @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  
  // Item Details
  lineNumber      Int?
  materialCode    String?
  materialDesc    String?
  orderUnit       String?
  rate            Decimal?  @db.Decimal(19,4)
  invoiceQuantity Decimal?  @db.Decimal(19,4)
  
  // Tracking
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  uploadRecords   vendor_upload_data[]

  @@index([purchaseOrderId])
  @@map("purchase_order_line_items")
}

// ========================================
// RAW UPLOAD DATA (audit trail)
// ========================================

model vendor_upload_data {
  id              String    @id @default(cuid())
  
  // Who uploaded
  uploadedById    String
  uploadedBy      users     @relation(fields: [uploadedById], references: [id])
  
  // File info
  fileName        String
  rowNumber       Int
  uploadedAt      DateTime  @default(now())
  
  // Status
  status          String    @default("processed")
  errorMessage    String?
  
  // Raw Excel data
  email           String?
  supplierCode    String
  supplierName    String
  plantCode       String?
  poNumber        String
  poCreateDate    DateTime?
  poAmendDate     DateTime?
  materialCode    String?
  materialDesc    String?
  lineItem        Int?
  orderUnit       String?
  rate            Decimal?  @db.Decimal(19,4)
  invoiceQuantity Decimal?  @db.Decimal(19,4)
  
  // Relations to created records
  vendorId        String?
  vendor          vendors?         @relation(fields: [vendorId], references: [id])
  poId            String?
  purchaseOrder   purchase_orders? @relation(fields: [poId], references: [id])
  lineItemId      String?
  poLineItem      purchase_order_line_items? @relation(fields: [lineItemId], references: [id])

  @@index([supplierCode])
  @@index([poNumber])
  @@index([vendorId])
  @@index([uploadedAt])
  @@map("vendor_upload_data")
}

// ========================================
// VENDOR INVITATIONS (email tracking)
// ========================================

model vendor_invitations {
  id              String    @id @default(cuid())
  vendorId        String
  vendor          vendors   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  
  email           String
  username        String
  tempPassword    String
  invitationToken String    @unique
  
  status          String    @default("pending")
  sentAt          DateTime?
  acceptedAt      DateTime?
  expiresAt       DateTime
  
  createdAt       DateTime  @default(now())

  @@index([vendorId])
  @@index([invitationToken])
  @@index([status])
  @@map("vendor_invitations")
}
model portal_settings {
  id                  String    @id @default(cuid())
  companyId           String?   // If you have multi-tenant
  portalEnabled       Boolean   @default(true)
  selfRegistration    Boolean   @default(true)
  invoiceSubmission   Boolean   @default(true)
  paymentTracking     Boolean   @default(true)
  documentUpload      Boolean   @default(true)
  messaging           Boolean   @default(false)
  updatedAt           DateTime  @updatedAt
  updatedBy           String?

  @@map("portal_settings")
}